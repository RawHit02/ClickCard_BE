PORT=5000
NODE_ENV=development

# Database Configuration (Update with your Neon DB connection string)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# JWT Configuration (Generate and use a strong secret key)
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_change_in_production
REFRESH_TOKEN_EXPIRE=30d

# Email Configuration (Gmail setup required)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@clickcard.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# OTP Configuration
OTP_EXPIRY=10
OTP_LENGTH=6

# Frontend URL (Update with your frontend URL)
FRONTEND_URL=http://localhost:3000
